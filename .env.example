# 飞书推送
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_RECEIVE_ID=your_receive_id
FEISHU_WEBHOOK_URL=https://open.larkoffice.com/open-apis/bot/v2/hook/your_webhook_id

# 火山引擎 DeepSeek API
ARK_API_KEY=your_api_key
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=your_endpoint_id

# GLM 抢单
GLM_TOKEN=your_token
GLM_AUTH_FILE=path/to/bigmodel_auth.json

# 数据根目录（也可在 config.yaml 中配置）
# TRADING_DATA_ROOT=~/trading-data
